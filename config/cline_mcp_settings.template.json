{
  "mcpServers": {
    "unreal-rag": {
      "command": "{PYTHON_EXE}",
      "args": [
        "{REPO_ROOT}/scripts/unreal_rag_mcp.py",
        "--index",
        "{REPO_ROOT}/data/unreal58/rag.sqlite"
      ],
      "timeout": 420000,
      "env": {
        "SHARED_UNREAL_CONFIG": "{LMSTUDIO_HOME}/config/unreal-workspace.json",
        "UNREAL58_ROOT": "{REPO_ROOT}",
        "PYTHONUTF8": "1",
        "PYTHONIOENCODING": "utf-8",
        "MCP_ESSENTIAL_TOOLS": "1"
      }
    },
    "unreal-agent": {
      "command": "{NODE_EXE}",
      "args": [
        "{AGENT_MCP_ROOT}/src/server.js"
      ],
      "env": {
        "WORKSPACE_ROOT": "{USER_DOCUMENTS}",
        "AGENT_MCP_CONFIG": "{AGENT_MCP_ROOT}/config/agent-mcp.json",
        "SHARED_UNREAL_CONFIG": "{LMSTUDIO_HOME}/config/unreal-workspace.json",
        "UNREAL58_ROOT": "{REPO_ROOT}",
        "MCP_ESSENTIAL_TOOLS": "1",
        "MCP_REQUIRE_PLAN_AUTH": "1"
      }
    }
  }
}
