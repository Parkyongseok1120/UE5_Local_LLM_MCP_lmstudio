{
  "description": "Public-safe 36-case real-project holdout seeds for Unreal compile-fix and small multi-file refactor workflow evaluation. These are compact log-style cases, not proprietary project reproductions.",
  "suite": "real-project-holdout-v0",
  "tier": "real-project-holdout",
  "defaults": {
    "maxAttempts": 5,
    "minPassRate": 0.7,
    "reportPassAt1": true
  },
  "cases": [
    {
      "id": "holdout_gameplaytags_missing_module",
      "category": "GameplayTags dependency issue",
      "mode": "module_fix",
      "errorLog": "fatal error C1083: Cannot open include file: 'GameplayTagContainer.h': No such file or directory",
      "expectedFilesToRead": [
        "Source/<Module>/<Module>.Build.cs",
        "failing source/header"
      ],
      "expectedPatchTargets": [
        "owner Build.cs"
      ],
      "forbiddenPatchTargets": [
        "unrelated gameplay class"
      ],
      "expectedModules": [
        "GameplayTags"
      ],
      "expectedErrorSubkind": "C1083_MISSING_INCLUDE",
      "notes": "Module resolver should identify GameplayTags before a Build.cs patch is proposed.",
      "evalTier": "module_fix"
    },
    {
      "id": "holdout_enhanced_input_missing_module",
