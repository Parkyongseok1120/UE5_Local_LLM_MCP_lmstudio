{
  "name": "Evidence-First Integrated Coding Stack",
  "version": "2.1.0",
  "requires": {
    "python": "3.10+",
    "node": "20+",
    "lmStudio": "0.4+"
  },
  "profiles": {
    "safe": ["codex", "lmstudio"],
    "standard": ["codex", "lmstudio", "unreal"],
    "full": ["codex", "lmstudio", "unreal", "context_compactor"],
    "custom": []
  },
  "components": [
    "codex",
    "lmstudio",
    "portable_rule",
    "unreal",
    "context_compactor",
    "cline"
  ],
  "safety": {
    "defaultReadOnly": true,
    "agentModeRequires": ["--enable-agent-mode", "--accept-agent-risk"],
    "interactiveAgentModeSelector": true,
    "indexTierIsIndependent": true
  },
  "portablePackage": {
    "launchers": ["INSTALL.bat", "install.sh"],
    "indexIncludedByDefault": false,
    "supportedHosts": ["windows", "linux", "macos"]
  }
}
